---
// Barras verticais agrupadas (N séries por categoria) — espelha `_barras_v2`
// do site atual ("Ações, participações e impacto por ano"). Preenche a largura
// do card (viewBox fixo + width:100%): os grupos se distribuem uniformemente.
// <title> por barra (hover).
interface Serie { label: string; color: string; values: number[] }
interface Props { categorias: string[]; series: Serie[]; unidade?: string }
const { categorias, series, unidade = '' } = Astro.props;

const n = Math.max(categorias.length, 1);
const g = Math.max(series.length, 1);
const W = 760, H = 240, padL = 40, padR = 14, padT = 16, padB = 30;
const innerW = W - padL - padR;
const chartH = H - padT - padB;
const slot = innerW / n;                                  // faixa por categoria
const barW = Math.max(6, Math.min(30, (slot * 0.7) / g)); // largura da barra
const gap = Math.min(6, barW * 0.25);
const groupW = g * barW + (g - 1) * gap;

const maxV = Math.max(...series.flatMap((s) => s.values), 1);
const y = (v: number) => padT + chartH * (1 - v / maxV);
const gx = (i: number) => padL + slot * i + (slot - groupW) / 2;
const ticks = [0, 0.5, 1];
---
<div class="gb">
  <svg viewBox={`0 0 ${W} ${H}`} width="100%" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Barras agrupadas por ano">
    {ticks.map((f) => (
      <g>
        <line x1={padL} x2={W - padR} y1={y(maxV * f)} y2={y(maxV * f)} class="gline" />
        <text x={padL - 8} y={y(maxV * f) + 3.5} text-anchor="end" class="axis">{Math.round(maxV * f)}</text>
      </g>
    ))}
    {categorias.map((cat, i) => (
      <g>
        {series.map((s, k) => {
          const x = gx(i) + k * (barW + gap);
          const vv = s.values[i] ?? 0;
          const h = Math.max(0, padT + chartH - y(vv));
          return (
            <>
              <rect x={x} y={y(vv)} width={barW} height={h} rx="2.5" fill={s.color}>
                <title>{cat} · {s.label}: {vv.toLocaleString('pt-BR')}{unidade}</title>
              </rect>
              {vv > 0 && (
                <text x={x + barW / 2} y={y(vv) < padT + 18 ? y(vv) + 14 : y(vv) - 5}
                  text-anchor="middle" class="gb-val" fill={y(vv) < padT + 18 ? '#fff' : s.color}>{vv.toLocaleString('pt-BR')}</text>
              )}
            </>
          );
        })}
        <text x={gx(i) + groupW / 2} y={H - 10} text-anchor="middle" class="axis">{cat}</text>
      </g>
    ))}
  </svg>
  <div class="legend">
    {series.map((s) => (<span><i style={`background:${s.color}`}></i>{s.label}</span>))}
  </div>
</div>

<style>
  .gb svg { display: block; width: 100%; height: auto; }
  .gb :global(text.gb-val) { font-size: 11px; font-weight: 600; font-variant-numeric: tabular-nums; }
</style>
