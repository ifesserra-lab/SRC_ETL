---
// Grafo de colaboração — espelha a "Rede de colaboração" (painel) e o
// "Trabalhou com" (ego, extensionista). Layout radial elíptico determinístico:
// preenche a largura do card (nós numa elipse larga). Modo ego = nó 0 no centro.
// Espessura da aresta ∝ peso; nome no <title> (hover). Sem dependência externa.
interface Props {
  nodes: string[];
  edges: number[][]; // [i, j, peso]
  ego?: boolean;
  height?: number;
}
const { nodes, edges, ego = false, height = 400 } = Astro.props;
const W = 1000, H = height;
const cx = W / 2, cy = H / 2;
const rx = W / 2 - 130;   // elipse larga → usa a largura
const ry = H / 2 - 56;

// grau ponderado por nó (raio ∝ grau)
const grau = nodes.map(() => 0);
for (const [i, j, w] of edges) { grau[i] += w; grau[j] += w; }
const gmax = Math.max(...grau, 1);

const pos = nodes.map((_, idx) => {
  if (ego && idx === 0) return { x: cx, y: cy };
  const m = ego ? nodes.length - 1 : nodes.length;
  const k = ego ? idx - 1 : idx;
  const ang = (2 * Math.PI * k) / (m || 1) - Math.PI / 2;
  return { x: cx + rx * Math.cos(ang), y: cy + ry * Math.sin(ang) };
});
const wmax = Math.max(...edges.map((e) => e[2]), 1);
const primeiroNome = (s: string) => (s || '').split(/\s+/)[0];
---
<div class="ng">
  <svg viewBox={`0 0 ${W} ${H}`} width="100%" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Grafo de colaboração">
    {edges.map(([i, j, w]) => (
      <line x1={pos[i].x} y1={pos[i].y} x2={pos[j].x} y2={pos[j].y}
        stroke="var(--c1)" stroke-opacity={0.16 + 0.5 * (w / wmax)}
        stroke-width={1 + 4 * (w / wmax)} stroke-linecap="round">
        <title>{nodes[i]} — {nodes[j]}: {w} ação(ões)</title>
      </line>
    ))}
    {nodes.map((nome, idx) => {
      const r = ego && idx === 0 ? 20 : 7 + 11 * (grau[idx] / gmax);
      const isCenter = ego && idx === 0;
      const below = pos[idx].y > cy + 4;   // rótulo abaixo p/ nós na metade de baixo
      return (
        <g>
          <circle cx={pos[idx].x} cy={pos[idx].y} r={r}
            fill={isCenter ? 'var(--c1)' : 'var(--c2)'} stroke="var(--surface)" stroke-width="2.5">
            <title>{nome}{grau[idx] ? ` — ${grau[idx]} colaboração(ões)` : ''}</title>
          </circle>
          <text x={pos[idx].x} y={below ? pos[idx].y + r + 15 : pos[idx].y - r - 7}
            text-anchor="middle" class="ng-lbl" style="pointer-events:none">{primeiroNome(nome)}</text>
        </g>
      );
    })}
  </svg>
</div>

<style>
  .ng { overflow-x: auto; }
  .ng svg { display: block; width: 100%; height: auto; }
  .ng :global(text.ng-lbl) { fill: var(--text-2); font-size: 13px; }
</style>
